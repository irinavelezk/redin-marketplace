{
  "name": "@redin/sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./appsheet": "./src/appsheet.ts",
    "./mirror": "./src/mirror.ts"
  },
  "scripts": {
    "dev": "tsx --env-file=../.env.local --watch src/runner.ts",
    "start": "tsx --env-file=../.env.local src/runner.ts",
    "once": "tsx --env-file=../.env.local src/once.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@redin/shared": "*",
    "@redin/tools": "*",
    "@supabase/supabase-js": "^2.46.1",
    "node-cron": "^3.0.3",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
